# Shared by frontend/ (via vite.config.js envDir) and backend/ (via src/config/env.js).
# Copy this file to .env at the repo root and fill in real values locally.

# --- Frontend (Vite) ---
# Exposed to the client bundle — must be prefixed VITE_. Never put secrets here.
VITE_SQUARE_APP_ID=
VITE_SQUARE_LOCATION_ID=

# --- Backend ---
# Server-side only, never exposed to the client.
PORT=4000
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
